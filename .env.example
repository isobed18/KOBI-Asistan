# ── LLM: yerel Ollama veya Google Gemini ──
# Yerel: Ollama çalışırken API anahtarı gerekmez.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:27b

# Bulut (Gemini): LLM_PROVIDER=gemini yapın; Google AI Studio veya Vertex ile alınan anahtar:
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ── Telegram (isteğe bağlı) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ENABLED=false
