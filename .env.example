# ── LLM Provider Secimi ──
# Desteklenen: "ollama", "openai", "gemini", "claude"
LLM_PROVIDER=ollama

# ── Ollama (Local — API key gereksiz) ──
OLLAMA_BASE_URL=http://localhost:11434
